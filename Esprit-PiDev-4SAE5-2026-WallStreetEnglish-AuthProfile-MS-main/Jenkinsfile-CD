pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'mohamedseddikhafidh'
        VM_IP = '192.168.168.128'
    }

    stages {

        stage('Deploy to Kubernetes') {
            steps {
                echo "☸️ Deploying to Kubernetes..."
                sh """
                    kubectl set image deployment/auth-service \
                        auth-service=${DOCKER_HUB_USER}/auth-service:latest

                    kubectl set image deployment/user-service \
                        user-service=${DOCKER_HUB_USER}/user-management-service:latest

                    kubectl rollout status deployment/auth-service
                    kubectl rollout status deployment/user-service
                """
                echo "✅ Deployed to Kubernetes"
            }
        }

        stage('Verify Deployment') {
            steps {
                sh """
                    kubectl get pods
                    kubectl get svc
                """
            }
        }
    }

    post {
        success {
            echo """
🎉 CD Pipeline terminé avec succès!
☸️ Kubernetes mis à jour avec les dernières images!
🌐 Services disponibles:
   Keycloak:     http://${VM_IP}:32295
   Eureka:       http://${VM_IP}:32027
   RabbitMQ:     http://${VM_IP}:31803
   API Gateway:  http://${VM_IP}:30475
   Auth Service: http://${VM_IP}:32627
   User Service: http://${VM_IP}:30997
"""
        }
        failure {
            echo "❌ CD Pipeline échoué"
        }
    }
}